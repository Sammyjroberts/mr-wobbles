<!-- ============================================================= -->
<!--  TWO-WHEEL SELF-BALANCER  -  the "plant" (the physics model)  -->
<!-- ============================================================= -->
<!--
  Everything you'd tune to match your REAL hardware lives in this file.
  These are the "configurable motor vals" we talked about: edit the
  numbers here, the controller in balance.py stays the same.

  Coordinate convention (important - this is what the controller assumes):
    x = forward/back      (the direction it drives + the direction it falls)
    y = left/right        (the wheel axle axis)
    z = up
    PITCH = rotation about y = the balancing axis. +pitch = nose tips forward (+x).
-->
<mujoco model="balancer">
  <compiler angle="radian" autolimits="true"/>

  <!-- 500 Hz physics. RK4 = accurate integrator, good for contact-light systems. -->
  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.001"/>
    <geom friction="1.0 0.005 0.0001"/>   <!-- sliding/torsional/rolling friction -->
  </default>

  <worldbody>
    <light pos="0 0 2"/>
    <geom name="floor" type="plane" size="0 0 0.05" rgba="0.3 0.3 0.35 1"/>

    <!-- ===================== THE ROBOT ===================== -->
    <!-- pos z = wheel radius, so the wheels start resting on the floor. -->
    <body name="chassis" pos="0 0 0.035">
      <!-- freejoint = the robot is free in 3D. It will fall in PITCH (about y);
           the two wheels keep it from falling sideways (roll), exactly like
           the real thing. Yaw is steerable by driving the wheels differentially. -->
      <freejoint name="root"/>

      <!-- The "stick": a tall body whose mass sits HIGH above the axle.
           mass + size here set your center-of-mass height = the single biggest
           factor in how hard/easy it is to balance. Taller CoM = SLOWER fall
           = EASIER (broom vs pencil). 0.6 kg, CoM ~0.11 m above the axle. -->
      <geom name="body" type="box" pos="0 0 0.11" size="0.03 0.05 0.10"
            mass="0.6" rgba="0.85 0.4 0.2 1"/>
      <!-- battery slung low (lowers CoM a touch, like a real pack near the base) -->
      <geom name="battery" type="box" pos="0 0 0.02" size="0.025 0.04 0.015"
            mass="0.15" rgba="0.15 0.15 0.15 1"/>

      <!-- IMU site: where we "mount" the gyro/accel. Up on the body. -->
      <site name="imu" pos="0 0 0.10" size="0.005" rgba="0 1 0 1"/>

      <!-- ===== LEFT WHEEL ===== (at +y) -->
      <body name="left_wheel" pos="0 0.075 0">
        <joint name="left" type="hinge" axis="0 1 0"/>
        <!-- cylinder's long axis aligned to y via zaxis, so it rolls about y -->
        <geom name="left_tire" type="cylinder" size="0.035 0.0125" zaxis="0 1 0"
              mass="0.05" rgba="0.1 0.1 0.1 1"/>
      </body>

      <!-- ===== RIGHT WHEEL ===== (at -y) -->
      <body name="right_wheel" pos="0 -0.075 0">
        <joint name="right" type="hinge" axis="0 1 0"/>
        <geom name="right_tire" type="cylinder" size="0.035 0.0125" zaxis="0 1 0"
              mass="0.05" rgba="0.1 0.1 0.1 1"/>
      </body>
    </body>
  </worldbody>

  <!-- ===================== MOTORS ===================== -->
  <!-- Direct-torque actuators. ctrlrange = torque limit in N*m at the wheel.
       Your real motor: 20.4:1 gearbox, 3.2 kg*cm stall = ~0.31 N*m.
       So ctrl in [-0.31, 0.31]. Edit these to re-spec the motor later. -->
  <actuator>
    <motor name="left_motor"  joint="left"  ctrlrange="-0.31 0.31"/>
    <motor name="right_motor" joint="right" ctrlrange="-0.31 0.31"/>
  </actuator>

  <!-- ===================== SENSORS ===================== -->
  <!-- This is your sensor suite, matching real hardware:
       - gyro + accelerometer = your IMU (MPU6050 etc.)
       - jointpos/jointvel on the wheels = your motor ENCODERS -->
  <sensor>
    <framequat   name="imu_quat" objtype="site" objname="imu"/>
    <gyro        name="imu_gyro" site="imu"/>
    <accelerometer name="imu_acc" site="imu"/>
    <jointpos name="left_enc"  joint="left"/>
    <jointpos name="right_enc" joint="right"/>
    <jointvel name="left_vel"  joint="left"/>
    <jointvel name="right_vel" joint="right"/>
  </sensor>
</mujoco>
